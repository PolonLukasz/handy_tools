NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side only override (optional). Used by Next.js SSR inside Docker where
# the browser-facing URL doesn't resolve — e.g. API_INTERNAL_URL=http://backend:8000
# API_INTERNAL_URL=http://localhost:8000

# Overrides the input for `npm run generate:api` / `npm run fetch:spec`.
# Defaults to NEXT_PUBLIC_API_URL + /openapi.json, or a local file path.
# OPENAPI_INPUT=./openapi.json
